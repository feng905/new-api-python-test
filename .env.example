# new-api 自动化测试配置
# 复制此文件为 .env 并填入实际值：cp .env.example .env

# 被测系统地址
BASE_URL=http://localhost:3000

# new-api 数据库路径（用于 request_id 覆盖率检查）
DB_PATH=../new-api/one-api.db

# 有效的 API Token
VALID_TOKEN=sk-your-valid-token-here

# 无效的 API Token（用于鉴权失败测试）
INVALID_TOKEN=sk-invalid-token-00000000000000000000000000000000

# 测试使用的模型名称
TEST_MODEL_OPENAI=gpt-3.5-turbo
